{
  "name": "vscode-data-viewer",
  "displayName": "Data Viewer",
  "description": "Browse and query parquet, csv, json, xlsx files with DuckDB SQL",
  "version": "0.1.7",
  "publisher": "l1xnan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/l1xnan/vscode-data-viewer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:dataViewer.explorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "data-viewer",
          "title": "Data Viewer",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "data-viewer": [
        {
          "id": "dataViewer.explorer",
          "name": "Data Files",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "dataViewer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "dataViewer.openFile",
        "title": "Open Data File"
      },
      {
        "command": "dataViewer.newSqlFile",
        "title": "New SQL Query",
        "icon": "$(add)"
      },
      {
        "command": "dataViewer.openSqlFile",
        "title": "Open SQL Query"
      },
      {
        "command": "dataViewer.runSqlFileQuery",
        "title": "Run SQL Query",
        "icon": "$(play)"
      },
      {
        "command": "dataViewer.runSqlFileStatement",
        "title": "Run SQL Statement",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dataViewer.refresh",
          "when": "view == dataViewer.explorer",
          "group": "navigation@1"
        },
        {
          "command": "dataViewer.newSqlFile",
          "when": "view == dataViewer.explorer",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "dataViewer.runSqlFileQuery",
          "when": "editorLangId == sql && resourceDirname =~ /[\\\\/]\\.dataviewer[\\\\/]queries/",
          "group": "navigation@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "dataViewer.runSqlFileQuery",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorLangId == sql && resourceDirname =~ /[\\\\/]\\.dataviewer[\\\\/]queries/"
      }
    ],
    "configuration": {
      "title": "Data Viewer",
      "properties": {
        "dataViewer.pageSize": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "maximum": 10000,
          "description": "Default rows per page (LIMIT)"
        },
        "dataViewer.excludeFolders": {
          "type": "array",
          "default": [
            ".git",
            "node_modules",
            "dist",
            ".vscode",
            ".venv",
            "venv",
            "__pycache__",
            ".dataviewer"
          ],
          "description": "Folder names excluded from the Data Files tree (matched at any path segment)"
        },
        "dataViewer.excludeGlobs": {
          "type": "array",
          "default": [
            "**/.git/**",
            "**/node_modules/**",
            "**/dist/**",
            "**/.vscode/**",
            "**/.venv/**",
            "**/venv/**",
            "**/__pycache__/**"
          ],
          "description": "Glob patterns to exclude from file scan (advanced)"
        },
        "dataViewer.supportedExtensions": {
          "type": "array",
          "default": [
            ".parquet",
            ".csv",
            ".tsv",
            ".json",
            ".jsonl",
            ".ndjson",
            ".xlsx"
          ],
          "description": "File extensions shown in the data explorer"
        }
      }
    }
  },
  "scripts": {
    "build:extension": "vite build --config vite.config.extension.ts",
    "build:webview": "vite build --config vite.config.webview.ts",
    "build": "npm run build:webview && npm run build:extension",
    "watch:extension": "vite build --config vite.config.extension.ts --watch",
    "watch:webview": "vite build --config vite.config.webview.ts --watch",
    "dev": "concurrently \"npm:watch:extension\" \"npm:watch:webview\"",
    "test": "node scripts/integration-test.mjs",
    "prune:duckdb-bindings": "node scripts/prune-duckdb-bindings.mjs",
    "package:vsix": "npm run build && npm run prune:duckdb-bindings && npx @vscode/vsce package",
    "vscode:prepublish": "npm run build && npm run prune:duckdb-bindings"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@duckdb/node-api": "^1.5.4-r.1",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-table": "^8.21.3",
    "@vscode/codicons": "^0.0.45",
    "codemirror": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@types/vscode-webview": "^1.57.5",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "typescript": "^7.0.1-rc",
    "vite": "^8.1.3"
  }
}
